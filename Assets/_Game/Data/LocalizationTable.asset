    zh: '医学博士'
    en: 'MEDICAL DOCTOR'
  - key: hud.research_future
    zh: '未来人才'
    en: 'FUTURE TALENT'
  - key: hud.equipment_reserved
    zh: '选择士兵 · 模组位预留'
    en: 'SELECT SOLDIER · MODULE SLOTS RESERVED'
