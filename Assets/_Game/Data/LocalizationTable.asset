    zh: '自由成虫产下了一枚虫卵'
    en: 'A free adult has laid an egg'
  - key: toast.egg_sold
    zh: '虫卵已回收：+{0} 金币'
    en: 'Egg reclaimed: +{0} coins'
  - key: toast.bug_born
    zh: '新的幼体破壳而出'
    en: 'A young bug has hatched'
  - key: toast.bug_died
    zh: '一只洞穴虫回归沙海'
    en: 'A cave bug returns to the sands'
  - key: toast.bug_bought
    zh: '幼体已送入育巢'
    en: 'A young bug enters the nursery'
  - key: toast.insufficient_funds
    zh: '金币不足，无法引入幼体'
    en: 'Not enough coins to bring in a young bug'
  - key: toast.food_bought
    zh: '食物已入库'
    en: 'Food added to storage'
  - key: toast.food_used
    zh: '食物被抢到了，饥饿与健康得到恢复'
    en: 'Food claimed: hunger and health restored'
  - key: toast.no_food
    zh: '食物不足'
    en: 'Not enough food'
