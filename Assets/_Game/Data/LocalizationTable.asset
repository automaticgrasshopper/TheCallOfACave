    zh: '工厂\n{0} 金币'
    en: 'FACTORY\n{0} COINS'
  - key: build.barracks
    zh: '兵营\n{0} 金币'
    en: 'BARRACKS\n{0} COINS'
  - key: build.hospital
    zh: '医院\n{0} 金币'
    en: 'HOSPITAL\n{0} COINS'
  - key: build.academy
    zh: '研究院\n{0} 金币'
    en: 'RESEARCH ACADEMY\n{0} COINS'
  - key: build.locked
    zh: '未解锁\n先建前置设施'
    en: 'LOCKED\nBUILD PREREQUISITE'
  - key: btn.language
    zh: 'EN'
    en: '中文'
  - key: btn.pause
    zh: '暂停'
    en: 'Pause'
  - key: btn.resume
    zh: '继续'
    en: 'Resume'
  - key: hint.feed
    zh: '按住左键拖拽投喂'
    en: 'Hold & drag to feed'
  - key: state.gameover
    zh: '全灭了…'
    en: 'All gone...'
  - key: gameover.title
    zh: '虫群失联'
    en: 'COLONY LOST'
  - key: gameover.body
    zh: '最后一只洞穴虫已消失在污染与黑暗中。重建巢群，再次回应洞穴的召唤。'
    en: 'The last cave bug vanished into pollution and darkness. Rebuild the colony and answer the cave again.'
  - key: gameover.restart
    zh: '重建巢群'
    en: 'REBUILD COLONY'
  - key: gameover.menu
    zh: '返回标题'
    en: 'RETURN TO TITLE'
  - key: toast.egg_laid
    zh: '自由成虫产下了一枚虫卵'
    en: 'A free adult has laid an egg'
  - key: toast.egg_sold
    zh: '虫卵已回收：+{0} 金币'
    en: 'Egg reclaimed: +{0} coins'
  - key: toast.bug_born
    zh: '新的幼体破壳而出'
    en: 'A young bug has hatched'
  - key: toast.bug_died
    zh: '一只洞穴虫回归沙海'
    en: 'A cave bug returns to the sands'
  - key: toast.bug_bought
    zh: '幼体已送入育巢'
    en: 'A young bug enters the nursery'
  - key: toast.insufficient_funds
    zh: '金币不足，无法引入幼体'
    en: 'Not enough coins to bring in a young bug'
  - key: toast.food_bought
    zh: '食物已入库'
    en: 'Food added to storage'
  - key: toast.food_used
    zh: '已投喂，健康正在恢复'
    en: 'Fed: health restored'
  - key: toast.no_food
    zh: '食物不足'
    en: 'Not enough food'
  - key: toast.built
    zh: '设施建造完成'
    en: 'Facility constructed'
  - key: toast.upgraded
    zh: '设施升级完成'
    en: 'Facility upgraded'
  - key: toast.facility_full
    zh: '设施容量已满'
    en: 'Facility is at capacity'
  - key: toast.adult_only
    zh: '只有自由成虫可以进入'
    en: 'Only a free adult can enter'
  - key: toast.part_ready
    zh: '工厂产物已进入背包，点击格子出售'
    en: 'Factory cargo stored; click its slot to sell'
  - key: toast.cargo_sold
    zh: '物资已出售：+{0} 金币'
    en: 'Cargo sold: +{0} coins'
  - key: toast.drag_food
    zh: '把食物拖到虫子身上进行投喂'
    en: 'Drag food onto a bug to feed it'
  - key: toast.equipment_ready
    zh: '外骨骼装备已进入背包，可出售或拖给工兵'
    en: 'Exoskeleton stored; sell it or drag it onto a soldier'
  - key: toast.elite_equipped
    zh: '外骨骼适配完成：工兵生命与攻击翻倍'
    en: 'Exoskeleton fitted: soldier health and damage doubled'
  - key: toast.elite_required
    zh: '外骨骼只能装备给尚未强化的工兵'
    en: 'Exoskeletons require an unupgraded soldier'
  - key: toast.heavy_invasion
    zh: '警报：重型机械侵略者进入洞穴'
    en: 'Alert: heavy mechanical invaders entered the cave'
  - key: toast.drag_to_build
    zh: '按住建造卡，拖到亮起的基地网格中'
    en: 'Hold a build card and drag it onto the highlighted base grid'
  - key: toast.build_blocked
    zh: '此处被占用，或三级建筑占地超出基地边界'
    en: 'Blocked: the level-3 footprint overlaps another site or the base boundary'
  - key: toast.build_locked
    zh: '该设施尚未解锁，请先建造前置设施'
    en: 'Facility locked: construct its prerequisite first'
  - key: toast.infected
    zh: '虫体受到污染，生命流逝加速'
    en: 'Bug infected; health and aging accelerated'
  - key: toast.cured
    zh: '感染已治愈，请将虫子带离医院'
    en: 'Infection cured; remove the bug from hospital'
  - key: toast.invasion
    zh: '右侧侦测到机械入侵者'
    en: 'Mechanical intruder detected on the right'
  - key: toast.doctor_started
    zh: '医学博士培养开始'
    en: 'Medical doctor training started'
  - key: toast.doctor_ready
    zh: '医学博士培养完成'
    en: 'Medical doctors are ready'
  - key: toast.need_academy_worker
    zh: '医学院需要一名自由成虫；每名博士消耗150金币和3份食物'
    en: 'Academy needs one free adult; each doctor costs 150 coins and 3 food'
  - key: zone.nursery
    zh: '育巢 · 孵化区'
    en: 'NURSERY · HATCHERY'
  - key: zone.factory
    zh: '工厂 · 劳作区'
    en: 'EXTRACTOR · WORK ZONE'
  - key: zone.barracks
    zh: '兵营 · 工兵训练'
    en: 'BARRACKS · SOLDIER TRAINING'
  - key: zone.hospital
    zh: '医院 · 治疗区'
    en: 'HOSPITAL · TREATMENT'
  - key: zone.academy
    zh: '研究院 · 人才培养'
    en: 'RESEARCH ACADEMY · TALENT TRAINING'
  - key: toast.training_started
    zh: '工兵训练开始：消耗两年寿命'
    en: 'Soldier training begins: two colony-years committed'
  - key: toast.soldier_ready
    zh: '工兵训练完成，剩余寿命减半'
    en: 'Soldier ready; remaining life is halved'
