    zh: '设施建造完成'
    en: 'Facility constructed'
  - key: toast.upgraded
    zh: '设施升级完成'
    en: 'Facility upgraded'
  - key: toast.facility_full
    zh: '设施容量已满'
    en: 'Facility is at capacity'
  - key: toast.adult_only
    zh: '只有自由成虫可以进入'
    en: 'Only a free adult can enter'
  - key: toast.part_ready
    zh: '工厂产物已进入背包，点击格子出售'
    en: 'Factory cargo stored; click its slot to sell'
  - key: toast.cargo_sold
    zh: '物资已出售：+{0} 金币'
    en: 'Cargo sold: +{0} coins'
  - key: toast.drag_food
    zh: '把食物拖到场景任意位置，附近的虫子会来争抢'
    en: 'Drop food anywhere; nearby bugs will race to claim it'
  - key: toast.food_dropped
    zh: '食物已放下，附近的虫子正在赶来'
    en: 'Food dropped; nearby bugs are on their way'
  - key: toast.equipment_ready
    zh: '外骨骼装备已进入背包，可出售或拖给工兵'
    en: 'Exoskeleton stored; sell it or drag it onto a soldier'
  - key: toast.advanced_part_a_ready
    zh: '三级工厂产出高级零件 A'
    en: 'Level-3 factory produced Advanced Part A'
  - key: toast.advanced_part_b_ready
    zh: '三级工厂产出高级零件 B'
    en: 'Level-3 factory produced Advanced Part B'
  - key: toast.craft_need_parts
    zh: '需要高级零件 A 和 B 各1个才能合成'
    en: 'Assembly requires one Advanced Part A and one Advanced Part B'
  - key: toast.equipment_crafted
    zh: '已合成装备'
    en: 'Equipment assembled'
  - key: toast.drag_equipment
    zh: '把装备拖给工兵、拖到金币区出售，或放到地上'
    en: 'Drag equipment to a soldier, the coin display to sell, or the ground to drop it'
  - key: toast.equipment_dropped
    zh: '装备已放在地上，点击可捡回背包'
    en: 'Equipment dropped; click it to return it to the backpack'
  - key: toast.equipment_picked_up
    zh: '装备已捡回背包'
    en: 'Equipment returned to the backpack'
  - key: toast.craft_need_advanced_parts
    zh: '需要1件合成装备和1个特殊零件'
    en: 'Requires one assembled equipment and one special enemy part'
  - key: toast.advanced_equipment_crafted
    zh: '已合成高级装备'
    en: 'Advanced equipment assembled'
  - key: toast.basic_part_picked_up
    zh: '已拾取初级零件'
    en: 'Basic part collected'
  - key: toast.special_part_picked_up
    zh: '已拾取特殊零件'
    en: 'Special enemy part collected'
  - key: toast.advanced_equipment_required
    zh: '高级装备只能用于尚未高级强化的士兵'
    en: 'Advanced equipment requires a soldier not already advanced'
  - key: toast.advanced_equipped
    zh: '高级装备完成：士兵恢复刚成年状态并满血'
    en: 'Advanced equipment fitted: soldier restored to newly adult age and full health'
  - key: toast.elite_equipped
    zh: '外骨骼适配完成：工兵生命与攻击翻倍'
    en: 'Exoskeleton fitted: soldier health and damage doubled'
  - key: toast.elite_required
    zh: '外骨骼只能装备给尚未强化的工兵'
    en: 'Exoskeletons require an unupgraded soldier'
  - key: toast.heavy_invasion
    zh: '警报：重型机械侵略者进入洞穴'
    en: 'Alert: heavy mechanical invaders entered the cave'
  - key: toast.drag_to_build
    zh: '按住建造卡，拖到亮起的基地网格中'
    en: 'Hold a build card and drag it onto the highlighted base grid'
  - key: toast.build_blocked
    zh: '此处被占用，或三级建筑占地超出基地边界'
    en: 'Blocked: the level-3 footprint overlaps another site or the base boundary'
  - key: toast.build_locked
    zh: '该设施尚未解锁，请先建造前置设施'
    en: 'Facility locked: construct its prerequisite first'
  - key: toast.infected
    zh: '虫体受到污染，生命流逝加速'
    en: 'Bug infected; health and aging accelerated'
  - key: toast.cured
    zh: '感染已治愈，请将虫子带离医院'
    en: 'Infection cured; remove the bug from hospital'
  - key: toast.invasion
    zh: '右侧侦测到机械入侵者'
    en: 'Mechanical intruder detected on the right'
  - key: toast.doctor_started
    zh: '医学博士培养开始'
    en: 'Medical doctor training started'
  - key: toast.doctor_ready
    zh: '医学博士培养完成'
    en: 'Medical doctors are ready'
  - key: toast.need_academy_worker
    zh: '医学院需要一名自由成虫；每名博士消耗150金币和3份食物'
    en: 'Academy needs one free adult; each doctor costs 150 coins and 3 food'
